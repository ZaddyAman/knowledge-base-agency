{
  "name": "knowledge-base-agency",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "corpus:fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fetch-demo-corpus.ps1",
